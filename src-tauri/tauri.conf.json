{
  "productName": "SmartBursar",
  "version": "0.1.0",
  "identifier": "com.smartbursar.app",
  "build": {
    "beforeDevCommand": "cd ../frontend && bun run dev",
    "beforeBuildCommand": "cd ../frontend && bun run build",
    "devUrl": "http://localhost:19173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SmartBursar",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true
  }
}

